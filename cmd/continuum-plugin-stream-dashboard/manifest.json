{
  "plugin_id": "continuum.stream-dashboard",
  "version": "1.0.0",
  "checksum": "__CHECKSUM__",
  "continuum_api_version": "v1",
  "supported_platforms": [
    {
      "os": "linux",
      "arch": "amd64"
    }
  ],
  "capabilities": [
    {
      "type": "http_routes.v1",
      "id": "dashboard",
      "display_name": "Stream Dashboard",
      "description": "Dashboard for Continuum active streams, playback history, map coverage, and globe view."
    },
    {
      "type": "scheduled_task.v1",
      "id": "sync-playback-history",
      "display_name": "Sync playback history",
      "description": "Copies Continuum playback history into the plugin schema and applies retention."
    }
  ],
  "http_routes": [
    {
      "id": "api",
      "method": "*",
      "path": "/api/*",
      "access": "authenticated"
    },
    {
      "id": "assets",
      "method": "GET",
      "path": "/assets/*",
      "access": "public"
    },
    {
      "id": "dashboard_root",
      "method": "GET",
      "path": "/dashboard",
      "access": "authenticated",
      "navigable": true,
      "navigation_label": "Stream Dashboard",
      "navigation_kind": "app"
    },
    {
      "id": "dashboard_app",
      "method": "GET",
      "path": "/dashboard/*",
      "access": "authenticated",
      "navigable": true,
      "navigation_label": "Stream Dashboard",
      "navigation_kind": "app"
    },
    {
      "id": "admin_root",
      "method": "GET",
      "path": "/admin",
      "access": "admin",
      "navigable": true,
      "navigation_label": "Stream Dashboard",
      "navigation_kind": "admin"
    },
    {
      "id": "admin_app",
      "method": "GET",
      "path": "/admin/*",
      "access": "admin"
    }
  ],
  "global_config_schema": [
    {
      "key": "plugin_database",
      "title": "Plugin database",
      "description": "Postgres DSN for the plugin-owned stream_dashboard schema.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"database_url\":{\"type\":\"string\"}},\"required\":[\"database_url\"]}",
      "required": true,
      "admin_form": {
        "fields": [
          {
            "key": "database_url",
            "label": "Plugin database URL",
            "control": "ADMIN_FORM_CONTROL_TEXT",
            "required": true
          }
        ]
      }
    },
    {
      "key": "continuum_database",
      "title": "Continuum source database",
      "description": "Read-only Postgres DSN for Continuum's public schema. Used to sync active sessions and playback history into the plugin schema.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"database_url\":{\"type\":\"string\"}},\"required\":[\"database_url\"]}",
      "required": true,
      "admin_form": {
        "fields": [
          {
            "key": "database_url",
            "label": "Continuum source URL",
            "control": "ADMIN_FORM_CONTROL_TEXT",
            "required": true
          }
        ]
      }
    },
    {
      "key": "stream_dashboard",
      "title": "Stream Dashboard settings",
      "description": "Dashboard refresh, retention, and GeoIP enrichment settings.",
      "json_schema": "{\"type\":\"object\",\"properties\":{\"refresh_seconds\":{\"type\":\"integer\",\"minimum\":5},\"default_server_lat\":{\"type\":\"number\"},\"default_server_lon\":{\"type\":\"number\"},\"history_retention_days\":{\"type\":\"integer\",\"minimum\":0},\"history_retention_max_rows\":{\"type\":\"integer\",\"minimum\":0},\"history_retention_min_seconds\":{\"type\":\"integer\",\"minimum\":0},\"history_retention_completed_only\":{\"type\":\"boolean\"},\"geoip_enabled\":{\"type\":\"boolean\"},\"geoip_database_path\":{\"type\":\"string\"},\"geoip_lookup_missing_coordinates\":{\"type\":\"boolean\"},\"geoip_override_session_coordinates\":{\"type\":\"boolean\"},\"geoip_lookup_cdn_nodes\":{\"type\":\"boolean\"},\"geoip_include_private_ips\":{\"type\":\"boolean\"},\"geoip_provider_order\":{\"type\":\"string\"},\"geoip_request_timeout_seconds\":{\"type\":\"integer\",\"minimum\":1},\"geoip_cache_ttl_seconds\":{\"type\":\"integer\",\"minimum\":60},\"geoip_cache_max_entries\":{\"type\":\"integer\",\"minimum\":100},\"geoip_ipapi_enabled\":{\"type\":\"boolean\"},\"geoip_ipapi_base_url\":{\"type\":\"string\"},\"geoip_ipinfo_enabled\":{\"type\":\"boolean\"},\"geoip_ipinfo_base_url\":{\"type\":\"string\"},\"geoip_ipinfo_token\":{\"type\":\"string\"},\"geoip_ipwhois_enabled\":{\"type\":\"boolean\"},\"geoip_ipwhois_base_url\":{\"type\":\"string\"}}}",
      "admin_form": {
        "submit_label": "Save",
        "fields": [
          {
            "key": "refresh_seconds",
            "label": "Refresh interval (seconds)",
            "control": "ADMIN_FORM_CONTROL_NUMBER"
          },
          {
            "key": "default_server_lat",
            "label": "Default server latitude",
            "control": "ADMIN_FORM_CONTROL_NUMBER"
          },
          {
            "key": "default_server_lon",
            "label": "Default server longitude",
            "control": "ADMIN_FORM_CONTROL_NUMBER"
          },
          {
            "key": "history_retention_days",
            "label": "History retention days",
            "control": "ADMIN_FORM_CONTROL_NUMBER"
          },
          {
            "key": "history_retention_max_rows",
            "label": "History max rows",
            "control": "ADMIN_FORM_CONTROL_NUMBER"
          },
          {
            "key": "history_retention_min_seconds",
            "label": "Minimum watch seconds",
            "control": "ADMIN_FORM_CONTROL_NUMBER"
          },
          {
            "key": "history_retention_completed_only",
            "label": "Keep completed plays only",
            "control": "ADMIN_FORM_CONTROL_CHECKBOX"
          },
          {
            "key": "geoip_enabled",
            "label": "Enable GeoIP lookup",
            "control": "ADMIN_FORM_CONTROL_CHECKBOX"
          },
          {
            "key": "geoip_database_path",
            "label": "GeoIP city database path",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          },
          {
            "key": "geoip_lookup_missing_coordinates",
            "label": "Fill missing session coordinates",
            "control": "ADMIN_FORM_CONTROL_CHECKBOX"
          },
          {
            "key": "geoip_override_session_coordinates",
            "label": "Override session coordinates",
            "control": "ADMIN_FORM_CONTROL_CHECKBOX"
          },
          {
            "key": "geoip_lookup_cdn_nodes",
            "label": "Resolve CDN node coordinates",
            "control": "ADMIN_FORM_CONTROL_CHECKBOX"
          },
          {
            "key": "geoip_include_private_ips",
            "label": "Lookup private/local IPs",
            "control": "ADMIN_FORM_CONTROL_CHECKBOX"
          },
          {
            "key": "geoip_provider_order",
            "label": "GeoIP provider order",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          },
          {
            "key": "geoip_request_timeout_seconds",
            "label": "GeoIP request timeout (seconds)",
            "control": "ADMIN_FORM_CONTROL_NUMBER"
          },
          {
            "key": "geoip_cache_ttl_seconds",
            "label": "GeoIP cache TTL (seconds)",
            "control": "ADMIN_FORM_CONTROL_NUMBER"
          },
          {
            "key": "geoip_cache_max_entries",
            "label": "GeoIP max cache entries",
            "control": "ADMIN_FORM_CONTROL_NUMBER"
          },
          {
            "key": "geoip_ipapi_enabled",
            "label": "Enable ip-api provider",
            "control": "ADMIN_FORM_CONTROL_CHECKBOX"
          },
          {
            "key": "geoip_ipapi_base_url",
            "label": "ip-api base URL",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          },
          {
            "key": "geoip_ipinfo_enabled",
            "label": "Enable IPinfo provider",
            "control": "ADMIN_FORM_CONTROL_CHECKBOX"
          },
          {
            "key": "geoip_ipinfo_base_url",
            "label": "IPinfo base URL",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          },
          {
            "key": "geoip_ipinfo_token",
            "label": "IPinfo token",
            "control": "ADMIN_FORM_CONTROL_PASSWORD"
          },
          {
            "key": "geoip_ipwhois_enabled",
            "label": "Enable ipwho.is provider",
            "control": "ADMIN_FORM_CONTROL_CHECKBOX"
          },
          {
            "key": "geoip_ipwhois_base_url",
            "label": "ipwho.is base URL",
            "control": "ADMIN_FORM_CONTROL_TEXT"
          }
        ]
      }
    }
  ]
}
